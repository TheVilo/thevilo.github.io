---
import Layout from "../layouts/Layout.astro";
import home from "../content/home.json";
import rest from "../content/index-rest.html?raw";

const hero = home.hero;
const karta = home.karta;
const staty = home.staty;
const heroStyle = `background: linear-gradient(rgba(21,23,28,0.85), rgba(21,23,28,0.85)), url('${hero.foto}'); background-size: cover; background-position: center;`;
---
<Layout title="FKM Karlova Ves — Futbalový klub mládeže | Jedna štvrť. Jeden klub. Jedno srdce.">
  <section class="hero" style={heroStyle}>
    <div class="hero-grid"></div>
    <div class="container">
      <div class="hero-inner">
        <div>
          <span class="hero-badge"><span class="dot"></span>{hero.badge}</span>
          <h1>{hero.riadok1}<br />{hero.riadok2}<br /><span class="accent">{hero.riadok3}</span></h1>
          <p class="hero-lead">{hero.text}</p>
          <div class="hero-actions">
            <a href={hero.button1Url} class="btn btn-primary">{hero.button1Label}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
            <a href={hero.button2Url} class="btn btn-ghost">{hero.button2Label}</a>
          </div>
          <div class="hero-stats">
            {staty.map((s) => (
              <div class="hero-stat"><div class="num">{s.num}</div><div class="lbl">{s.label}</div></div>
            ))}
          </div>
        </div>
        <aside class="hero-card">
          <span class="hc-tag">● {karta.tag}</span>
          <h3>{karta.titulok}</h3>
          <p>{karta.text}</p>
          <div class="hc-meta">
            <div class="hc-row"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>{karta.datum}</div>
            <div class="hc-row"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>{karta.miesto}</div>
            <div class="hc-row"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16v16H4z"/><path d="M4 4l8 8 8-8"/></svg>{karta.email}</div>
          </div>
          <a href={karta.buttonUrl} class="btn btn-primary">{karta.buttonLabel}</a>
        </aside>
      </div>
    </div>
  </section>

  <Fragment set:html={rest} />
</Layout>
