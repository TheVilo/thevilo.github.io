---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const items = await getCollection("novinky");
  return items.map((n) => ({ params: { slug: n.id }, props: { n } }));
}
const { n } = Astro.props;
const { Content } = await render(n);
const datum = n.data.datum.toLocaleDateString("sk-SK", { day: "numeric", month: "long", year: "numeric" });
---
<Layout title={`${n.data.titulok} • FKM Karlova Ves`} description={n.data.perex}>
  <section class="hero" style="min-height:auto;padding-block:64px;">
    <div class="container">
      <span class="eyebrow">{n.data.kategoria} · {datum}</span>
      <h1>{n.data.titulok}</h1>
    </div>
  </section>
  <section class="section">
    <div class="container" style="max-width:760px;">
      {n.data.foto && <img src={n.data.foto} alt={n.data.titulok} style="width:100%;border-radius:12px;margin-bottom:1.5rem;" />}
      <Content />
      <p style="margin-top:2rem;"><a href="/novinky" class="btn btn-outline">← Všetky novinky</a></p>
    </div>
  </section>
</Layout>
