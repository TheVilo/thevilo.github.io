---
interface Item {
  id: string;
  data: { titulok: string; datum: Date; kategoria: string; perex: string; foto: string };
}
interface Props { items: Item[]; base: string; }
const { items, base } = Astro.props;
const datum = (d: Date) =>
  d.toLocaleDateString("sk-SK", { month: "long", year: "numeric" });
---
<div class="news-grid">
  {items.map((n) => (
    <article class="news-card">
      <div class="news-thumb">
        <span class="nt-cat">{n.data.kategoria}</span>
        {n.data.foto ? (
          <img src={n.data.foto} alt={n.data.titulok} style="width:100%;height:100%;object-fit:cover;" />
        ) : (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="6"/><path d="M15.5 13.5L17 22l-5-3-5 3 1.5-8.5"/></svg>
        )}
      </div>
      <div class="news-body">
        <div class="date">{datum(n.data.datum)}</div>
        <h3>{n.data.titulok}</h3>
        <p>{n.data.perex}</p>
        <a href={`${base}/${n.id}`} class="more">Čítať viac
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>
    </article>
  ))}
</div>
